<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="me.astroreen.tilepad.ui.MainController"
            stylesheets="@styles/main.css">
    <bottom>
        <BorderPane styleClass="bottom-bar">
            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
            <left>
                <Button text="⚙" styleClass="icon-button" onAction="#onOpenEditor"/>
            </left>
            <center>
                <HBox alignment="CENTER" spacing="8">
                    <Button text="&#60;" styleClass="nav-button" onAction="#onPrevProfile"/>
                    <Label fx:id="profileNameLabel" styleClass="profile-name-label" minWidth="120" alignment="CENTER"/>
                    <Button text="&#62;" styleClass="nav-button" onAction="#onNextProfile"/>
                </HBox>
            </center>
            <right>
                <Region minWidth="36"/>
            </right>
        </BorderPane>
    </bottom>
    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" styleClass="main-scroll">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
        </ScrollPane>
    </center>
</BorderPane>
